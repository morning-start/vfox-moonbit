#!/usr/bin/env bash
#MISE description="运行插件测试 - 安装并执行 moonbit"
set -euo pipefail

mise plugin link --force moonbit .
mise cache clear
mise install moonbit@latest

# 验证安装
output=$(mise exec "moonbit@latest" -- moon version)
echo "moon 输出: $output"

if echo "$output" | grep -q '.'; then
    echo "✓ 测试通过"
else
    echo "✗ 测试失败：无法获取 moon 版本信息"
    exit 1
fi